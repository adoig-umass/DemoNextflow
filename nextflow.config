/*
 * ============================================================================
 *  nextflow.config
 * ============================================================================
 *
 *  Configuration file for the RNA-seq QC + trimming demo pipeline.
 *
 *  Nextflow automatically loads `nextflow.config` from the current directory
 *  when you run a pipeline. You can also pass additional configs with
 *  `-c some_other.config` on the command line — they get merged on top.
 *
 *  This file controls HOW the pipeline runs (executor, containers, resources,
 *  reporting), separate from WHAT the pipeline does (which lives in main.nf).
 *  Keeping the two separate means students can run the same main.nf on a
 *  laptop, an HPC cluster, or AWS just by swapping config files.
 * ============================================================================
 */


/*
 * ----------------------------------------------------------------------------
 *  MANIFEST
 * ----------------------------------------------------------------------------
 *  Metadata about the pipeline. Shown by `nextflow info`, used by nf-core
 *  tooling, and generally good practice. Optional but recommended.
 * ----------------------------------------------------------------------------
 */
manifest {
    name            = 'rnaseq-qc-demo'
    author          = 'Your Name'
    description     = 'Teaching demo: FastQC + fastp + MultiQC on paired-end RNA-seq'
    version         = '0.1.0'
    nextflowVersion = '>=22.10.0'   // require a reasonably modern Nextflow
}


/*
 * ----------------------------------------------------------------------------
 *  PARAMETERS
 * ----------------------------------------------------------------------------
 *  Default values for pipeline parameters. These can still be overridden
 *  on the command line with `--paramName value`.
 *
 *  TEACHING NOTE: We define `outdir` here as well as in main.nf because the
 *  config file is parsed BEFORE main.nf runs, and the report/timeline/dag
 *  blocks below need to know where to write their files. Values in main.nf
 *  override these, but for params the config-level definition is what's
 *  available at parse time.
 * ----------------------------------------------------------------------------
 */
params {
    outdir = "${projectDir}/results"
    reads  = "${projectDir}/data/*_{1,2}.fastq.gz"
}


/*
 * ----------------------------------------------------------------------------
 *  DOCKER CONFIGURATION
 * ----------------------------------------------------------------------------
 *  This block enables Docker globally and sets some sensible defaults.
 *
 *  TEACHING NOTE: There are TWO things going on here that students confuse:
 *
 *    1. `docker.enabled = true`   <-- turns the Docker integration ON
 *    2. `process.container = ...` <-- says WHICH image to use by default
 *
 *  You need both. Setting only #1 will make Nextflow complain that no
 *  container was specified. Setting only #2 has no effect because Docker
 *  isn't enabled.
 * ----------------------------------------------------------------------------
 */
docker {
    // Turn on Docker as the container engine for this run.
    enabled = true

    // `runOptions` are extra flags passed to `docker run`. The -u flag tells
    // Docker to run the container as the host user (UID:GID), so any files
    // the pipeline writes are owned by you, not by root. Without this, you'd
    // need `sudo` to delete the work/ directory after a run — a classic
    // beginner pain point that wastes a lot of time.
    runOptions = '-u $(id -u):$(id -g)'

    // Pull a fresh image only when needed (the default). Set to true if you
    // want Nextflow to always check the registry for an updated image.
    // For our locally-built `nf-rnaseq-demo:0.1`, leave this false — there
    // is no remote registry to pull from.
    fixOwnership = false
}


/*
 * ----------------------------------------------------------------------------
 *  PROCESS DEFAULTS
 * ----------------------------------------------------------------------------
 *  Settings under `process` apply to every process in the pipeline unless
 *  overridden in the process definition itself (like the `container`
 *  directives we wrote into main.nf). The `withName:` selector lets you
 *  target specific processes for fine-grained tuning.
 * ----------------------------------------------------------------------------
 */
process {

    // Default container for any process that doesn't specify its own.
    // Our main.nf already declares `container 'nf-rnaseq-demo:0.1'` per
    // process, but it's good practice to set a default here too — that
    // way, if someone adds a new process and forgets the container line,
    // the pipeline still works.
    container = 'nf-rnaseq-demo:0.1'

    // Default resource requests. The demo files are tiny so these are
    // generous; on a real dataset you'd tune per-process.
    cpus   = 2
    memory = '2 GB'
    time   = '1h'

    // What to do when a task fails. 'terminate' (the default) stops the
    // whole pipeline immediately. For teaching, that's actually what you
    // want — students see exactly which step broke. In production, people
    // often use 'retry' with maxRetries to handle transient failures.
    errorStrategy = 'terminate'

    /*
     * Per-process overrides go here. Example (commented out):
     *
     *   withName: FASTP {
     *       cpus   = 4
     *       memory = '4 GB'
     *   }
     *
     * For this small demo, the defaults above are plenty for every process,
     * so we don't override anything.
     */
}


/*
 * ----------------------------------------------------------------------------
 *  EXECUTOR CONFIGURATION
 * ----------------------------------------------------------------------------
 *  The executor decides WHERE tasks run. 'local' (the default) runs them
 *  on the current machine. Others include 'slurm', 'sge', 'awsbatch',
 *  'kubernetes' — Nextflow's portability story.
 *
 *  TEACHING NOTE: Switching from a laptop to an HPC cluster is usually
 *  just a one-line change here. main.nf doesn't need to know.
 * ----------------------------------------------------------------------------
 */
executor {
    name           = 'local'
    cpus           = 4    // total CPUs Nextflow may use across all tasks
    memory         = '8 GB'
    queueSize      = 10   // max tasks to run concurrently
}


/*
 * ----------------------------------------------------------------------------
 *  EXECUTION REPORTS
 * ----------------------------------------------------------------------------
 *  Nextflow can generate four useful reports automatically. They're
 *  excellent teaching aids — students get to SEE the parallel execution
 *  graph, per-task resource use, and timing.
 *
 *  All four go into ${params.outdir}/pipeline_info/ alongside the science
 *  outputs. Open the .html files in a browser after the run.
 * ----------------------------------------------------------------------------
 */

// Timeline: a Gantt chart showing when each task ran. Great for showing
// students the parallelism visually — they'll see three FastQC bars and
// three fastp bars all overlapping in time.
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/timeline.html"
    overwrite = true
}

// Report: per-task resource usage (CPU, memory, runtime, I/O). Useful for
// spotting which steps are bottlenecks on real data.
report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/report.html"
    overwrite = true
}

// Trace: a tab-separated text file with one row per task. Easy to grep
// or load into pandas if you want to analyze pipeline performance.
trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/trace.txt"
    overwrite = true
}

// DAG: visualizes the pipeline as a directed acyclic graph (which
// processes feed which). Requires Graphviz installed locally to render
// .png/.svg, but .html works out of the box. This is the single best
// teaching artifact for "what is a workflow, really?"
dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/dag.html"
    overwrite = true
}


/*
 * ----------------------------------------------------------------------------
 *  PROFILES (optional, for future expansion)
 * ----------------------------------------------------------------------------
 *  Profiles let you swap whole config blocks with `-profile <name>` on the
 *  command line. For this demo we don't need them, but here's the pattern
 *  for future reference:
 *
 *      profiles {
 *          docker     { docker.enabled     = true  }
 *          singularity{ singularity.enabled = true }
 *          conda      { conda.enabled       = true }
 *          test       { params.reads = 'data/*_{1,2}.fastq.gz' }
 *      }
 *
 *  You'd then run with:  nextflow run main.nf -profile docker
 * ----------------------------------------------------------------------------
 */
